# ── Database ────────────────────────────────────────────
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=ai_search
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres

# ── LLM Provider ────────────────────────────────────────
# เลือก: "anthropic" | "openai" | "ollama"
LLM_PROVIDER=ollama
LLM_MODEL=llama3.2          # ชื่อ model ที่ pull ไว้ใน Ollama

# Cloud API keys (ไม่ต้องใส่ถ้าใช้ Ollama อย่างเดียว)
ANTHROPIC_API_KEY=sk-ant-xxxxx
OPENAI_API_KEY=sk-xxxxx

# ── Embedding ────────────────────────────────────────────
# เลือก: "openai" | "ollama"
EMBEDDING_PROVIDER=ollama
# EMBEDDING_MODEL=nomic-embed-text   # 768 dims, เร็ว, ดีสำหรับภาษาอังกฤษ
EMBEDDING_MODEL=bge-m3           # 1024 dims, รองรับภาษาไทยได้ดีกว่า
# EMBEDDING_MODEL=mxbai-embed-large # 1024 dims

# ── Ollama server ────────────────────────────────────────
OLLAMA_BASE_URL=http://localhost:11434

# ── Search tuning ────────────────────────────────────────
MAX_RESULTS=1
MAX_CONTENT_LENGTH=3000
SIMILARITY_THRESHOLD=0.75
